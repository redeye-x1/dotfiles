# SSH Keys - ignore all keys (public and private)
.ssh/id_*
.ssh/*_rsa
.ssh/*_ed25519
.ssh/*_ecdsa
.ssh/*.pub
.ssh/known_hosts*

# Allow config only
!.ssh/config

# macOS
.DS_Store

# Vim
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Editor/Tool configs (generated/cache)
.config/github-copilot/

# OpenCode (track config and agents, but not sessions/history)
.config/opencode/sessions/
.config/opencode/history/
.config/opencode/.cache/

# Node modules (should be installed, not tracked)
node_modules/
bun.lock
package-lock.json
yarn.lock
.config/raycast/
