{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".config/opencode/bmad-rules.md"
  ],
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Full development work with all tools enabled",
      "temperature": 0.3
    },
    "plan": {
      "mode": "primary",
      "description": "Analysis and planning without making changes",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "bash": {
      "git push": "ask",
      "rm -rf": "ask",
      "npm publish": "ask"
    }
  },
  "autoupdate": true
}